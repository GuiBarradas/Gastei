# App
APP_ENV=development
DATABASE_URL=sqlite:///./data/gastei.db
SECRET_KEY=  # 32 bytes random base64, usado pra Fernet (gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")

# Pluggy
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_BASE_URL=https://api.pluggy.ai

# LLM provider — anthropic | gemini | none
LLM_PROVIDER=gemini

# Anthropic (precisa cartão após $5 trial)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_SMART=claude-opus-4-7

# Google Gemini (1500 req/dia grátis em https://aistudio.google.com/apikey)
GOOGLE_API_KEY=
# Aliases "-latest" acompanham a versão estável mais nova (versões pinadas são aposentadas e passam a dar 404).
# FAST (classificação em lote) usa o tier lite: mais barato e com folga de capacidade no free tier.
GEMINI_MODEL_FAST=gemini-flash-lite-latest
GEMINI_MODEL_SMART=gemini-flash-latest

# Sync
SYNC_INTERVAL_HOURS=6
ENABLE_SCHEDULER=false  # true em produção pra rodar sync auto a cada SYNC_INTERVAL_HOURS
